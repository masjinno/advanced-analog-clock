<Window x:Class="AdvancedAnalogClock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Advanced Analog Clock"
        Width="420"
        Height="420"
        MinWidth="260"
        MinHeight="260"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="ClockFaceFillBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="ClockOuterStrokeBrush" Color="#93C5FD" />
        <SolidColorBrush x:Key="ClockInnerStrokeBrush" Color="#1E293B" />

        <SolidColorBrush x:Key="TickBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="HourTickBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="NumberBrush" Color="#E2E8F0" />

        <SolidColorBrush x:Key="HourHandBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="MinuteHandBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="SecondHandBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="CenterDotFillBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="CenterDotStrokeBrush" Color="#0F172A" />

        <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#F8FAFC" />
    </Window.Resources>

    <Grid Margin="10" MouseLeftButtonDown="OnWindowDragMove">
        <Grid.ContextMenu>
            <ContextMenu Background="{DynamicResource MenuBackgroundBrush}"
                         Foreground="{DynamicResource MenuForegroundBrush}">
                <MenuItem Header="Theme">
                    <MenuItem x:Name="DarkModeMenuItem"
                              Header="Dark"
                              IsCheckable="True"
                              Click="OnDarkModeMenuClick" />
                    <MenuItem x:Name="LightModeMenuItem"
                              Header="Light"
                              IsCheckable="True"
                              Click="OnLightModeMenuClick" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Click="OnExitMenuClick" />
            </ContextMenu>
        </Grid.ContextMenu>

        <Viewbox Stretch="Uniform">
            <Grid Width="300" Height="300">
                <Grid.Clip>
                    <EllipseGeometry Center="150,150" RadiusX="148" RadiusY="148" />
                </Grid.Clip>

                <Ellipse Fill="{DynamicResource ClockFaceFillBrush}"
                         Stroke="{DynamicResource ClockOuterStrokeBrush}"
                         StrokeThickness="4" />

                <Ellipse Margin="8"
                         Stroke="{DynamicResource ClockInnerStrokeBrush}"
                         StrokeThickness="2" />

                <ItemsControl ItemsSource="{Binding TickMarks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="300" Height="300" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}"
                                  Y1="{Binding Y1}"
                                  X2="{Binding X2}"
                                  Y2="{Binding Y2}"
                                  Stroke="{DynamicResource TickBrush}"
                                  StrokeThickness="1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round">
                                <Line.Style>
                                    <Style TargetType="Line">
                                        <Setter Property="Stroke" Value="{DynamicResource TickBrush}" />
                                        <Setter Property="StrokeThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHourMark}" Value="True">
                                                <Setter Property="Stroke" Value="{DynamicResource HourTickBrush}" />
                                                <Setter Property="StrokeThickness" Value="2.6" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Line.Style>
                            </Line>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding NumberMarks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="300" Height="300" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{DynamicResource NumberBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Width="24"
                                       Height="24"
                                       Margin="-12,-12,0,0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Line X1="150"
                      Y1="150"
                      X2="150"
                      Y2="92"
                      Stroke="{DynamicResource HourHandBrush}"
                      StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Line.RenderTransform>
                        <RotateTransform Angle="{Binding HourAngle}" CenterX="150" CenterY="150" />
                    </Line.RenderTransform>
                </Line>

                <Line X1="150"
                      Y1="150"
                      X2="150"
                      Y2="66"
                      Stroke="{DynamicResource MinuteHandBrush}"
                      StrokeThickness="4"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Line.RenderTransform>
                        <RotateTransform Angle="{Binding MinuteAngle}" CenterX="150" CenterY="150" />
                    </Line.RenderTransform>
                </Line>

                <Line X1="150"
                      Y1="160"
                      X2="150"
                      Y2="48"
                      Stroke="{DynamicResource SecondHandBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round">
                    <Line.RenderTransform>
                        <RotateTransform Angle="{Binding SecondAngle}" CenterX="150" CenterY="150" />
                    </Line.RenderTransform>
                </Line>

                <Ellipse Width="12"
                         Height="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="{DynamicResource CenterDotFillBrush}"
                         Stroke="{DynamicResource CenterDotStrokeBrush}"
                         StrokeThickness="1.5" />
            </Grid>
        </Viewbox>
    </Grid>
</Window>
