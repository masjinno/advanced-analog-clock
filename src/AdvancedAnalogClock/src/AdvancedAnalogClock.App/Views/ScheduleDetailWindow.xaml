<Window x:Class="AdvancedAnalogClock.App.Views.ScheduleDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="予定の詳細"
        Width="460"
        Height="380"
        MinWidth="380"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="SubjectTextBlock"
                   FontSize="18"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <TextBlock x:Name="TimeTextBlock"
                   Grid.Row="1"
                   Margin="0,12,0,0"
                   FontSize="13"
                   Foreground="#334155" />

        <TextBlock x:Name="LocationTextBlock"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   FontSize="13"
                   Foreground="#475569"
                   TextWrapping="Wrap" />

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="10"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="BodyTextBlock"
                           TextWrapping="Wrap"
                           FontSize="13"
                           Foreground="#0F172A" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OpenJoinLinkButton"
                    Content="参加リンクを開く"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="OnOpenJoinLinkClick" />
            <Button Content="閉じる"
                    Padding="12,6"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnCloseClick" />
        </StackPanel>
    </Grid>
</Window>
